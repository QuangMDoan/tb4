#!/usr/bin/env bash
set -e

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "Error: required command '$1' not found."
    exit 1
  }
}

deg_to_rad() {
  echo "$1 * 3.141592653589793 / 180" | bc -l
}

usage() {
  cat <<'EOF'
Usage:
  tb4 undock
  tb4 dock
  tb4 fwd [distance_m] [speed_mps]
  tb4 back [distance_m] [speed_mps]
  tb4 turn [degrees] [max_rotation_speed]
  tb4 stop
  tb4 stop_lidar
  tb4 start_lidar
  tb4 chk_power_save
  tb4 restart
  tb4 status
  tb4 off
  tb4 baseline1
  tb4 square [side_m] [speed_mps]

Examples:
  tb4 undock
  tb4 fwd 0.508 0.08
  tb4 back 0.25 0.08
  tb4 turn 90 1.0
  tb4 turn -90 1.0
  tb4 stop
  tb4 stop_lidar
  tb4 start_lidar
  tb4 dock
  tb4 square 0.5 0.08
  tb4 restart
  tb4 status
  tb4 off
  tb4 baseline1

Setup: 
  mkdir -p ~/bin
  cp ~/turtlebot4_ws/src/turtlebot4/turtlebot4_navigation/config/tb4 ~/bin/tb4
  chmod +x ~/bin/tb4
  echo 'export PATH="$HOME/bin:$PATH"' >> ~/.bashrc
  source ~/.bashrc

EOF
}

dock_cmd() {
  ros2 action send_goal /dock irobot_create_msgs/action/Dock
}

undock_cmd() {
  ros2 action send_goal /undock irobot_create_msgs/action/Undock
}

fwd_cmd() {
  local dist="${1:-0.5}"
  local speed="${2:-0.1}"
  ros2 action send_goal /drive_distance irobot_create_msgs/action/DriveDistance \
    "{distance: $dist, max_translation_speed: $speed}"
}

back_cmd() {
  local dist="${1:-0.5}"
  local speed="${2:-0.1}"
  ros2 action send_goal /drive_distance irobot_create_msgs/action/DriveDistance \
    "{distance: -$dist, max_translation_speed: $speed}"
}

turn_cmd() {
  local deg="${1:-90}"
  local speed="${2:-1.0}"
  local rad
  need_cmd bc
  rad="$(deg_to_rad "$deg")"
  ros2 action send_goal /rotate_angle irobot_create_msgs/action/RotateAngle \
    "{angle: $rad, max_rotation_speed: $speed}"
}

stop_cmd() {
  ros2 topic pub --once /cmd_vel geometry_msgs/msg/TwistStamped \
    "{header: {frame_id: 'base_link'}, twist: {linear: {x: 0.0, y: 0.0, z: 0.0}, angular: {x: 0.0, y: 0.0, z: 0.0}}}"
}

stop_lidar_cmd() {
  ros2 service call /stop_motor std_srvs/srv/Empty
}

start_lidar_cmd() {
  ros2 service call /start_motor std_srvs/srv/Empty
}

chk_power_save_cmd() {
  ros2 param get /turtlebot4_node power_saver
}

restart_cmd() {
  ssh -t ubuntu@turtlebot4 'systemctl restart turtlebot4.service'
}

status_cmd() {
  ssh -t ubuntu@turtlebot4 'systemctl status turtlebot4.service'
}

off_cmd() {
  ros2 service call /robot_power irobot_create_msgs/srv/RobotPower "{}"
}

baseline1_cmd() {
  ros2 run tb4_baseline_python tb4_baseline_node
}

square_cmd() {
  local side="${1:-0.5}"
  local speed="${2:-0.1}"
  local i
  for i in 1 2 3 4; do
    fwd_cmd "$side" "$speed"
    turn_cmd 90 1.0
  done
}

case "${1:-}" in
  dock)
    shift
    dock_cmd "$@"
    ;;
  undock)
    shift
    undock_cmd "$@"
    ;;
  fwd)
    shift
    fwd_cmd "$@"
    ;;
  back)
    shift
    back_cmd "$@"
    ;;
  turn)
    shift
    turn_cmd "$@"
    ;;
  stop)
    shift
    stop_cmd "$@"
    ;;
  stop_lidar)
    shift
    stop_lidar_cmd "$@"
    ;;
  start_lidar)
    shift
    start_lidar_cmd "$@"
    ;;
  chk_power_save)
    shift
    chk_power_save_cmd "$@"
    ;;
  restart)
    shift
    restart_cmd "$@"
    ;;
  status)
    shift
    status_cmd "$@"
    ;;
  off)
    shift
    off_cmd "$@"
    ;;
  baseline1)
    shift
    baseline1_cmd "$@"
    ;;
  square)
    shift
    square_cmd "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: $1"
    echo
    usage
    exit 1
    ;;
esac